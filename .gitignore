# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ───────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Environment variables (contains API keys) ──────────────
.env
.env.local
.env.*.local
.env.development
.env.production

# ── Log data files — never commit sensitive log data ───────
public/data/*.csv
public/data/*.xlsx
public/data/*.xls
public/data/*.tsv
public/data/*.json
# Keep the data directory itself tracked (for README etc.)
!public/data/.gitkeep

# ── OS / editor artifacts ──────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.idea/
.vscode/settings.json

# ── Vite / tooling ─────────────────────────────────────────
*.local
.vite/
vite.config.js.timestamp-*