# Anthropic API key — required for the "AI Log Summary" panel in the Investigate tab.
# Get a key at https://console.anthropic.com/ (sign up, then API Keys).
# Copy this file to .env and set your key:
#   copy .env.example .env   (Windows)
#   cp .env.example .env    (Mac/Linux)
# Then edit .env and replace the placeholder with your key.

VITE_ANTHROPIC_KEY=your-anthropic-api-key-here
